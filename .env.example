# Ghost Economy Hunter — environment variables (copy to .env and fill real values)

# Required: Elasticsearch connection
ELASTIC_URL=https://your-project.es.us-central1.gcp.elastic.cloud
ELASTIC_API_KEY=your_api_key_here

# Required for Agent Builder: Kibana URL
KIBANA_URL=https://your-project.kb.us-central1.gcp.elastic.cloud

# Optional: Slack webhook for Action Taker alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Enable/disable Agent Builder calls (default: true)
AGENT_BUILDER_ENABLED=true

# Optional: Server port (default: 8000)
PORT=8000
